rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /usuarios/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /termos/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /registros/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /lockedDays/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /config/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /ubicaciones/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /calibraciones/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /diasNoLaborables/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
